# ----- LLM (OpenAI-compatible endpoint). Default = local Ollama (free, no key). -----
# Option A (free, local): install Ollama, run `ollama pull mistral`, leave these as-is.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=mistral
# Option B (hosted OpenAI):  LLM_BASE_URL=https://api.openai.com/v1  | LLM_API_KEY=sk-...  | LLM_MODEL=gpt-4o-mini
# Option C (Mistral API):    LLM_BASE_URL=https://api.mistral.ai/v1  | LLM_API_KEY=...     | LLM_MODEL=mistral-small-latest

# ----- Retrieval models (all local, no key needed) -----
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CHROMA_PATH=./data/chroma
COLLECTION=cranio_lit

# ----- Optional NCBI key (only speeds up ingestion; not required) -----
NCBI_API_KEY=
